# PWA Configuration
# Enable HTTPS redirection
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Security Headers for PWA
<IfModule mod_headers.c>
    # Service Worker
    Header always set Service-Worker-Allowed "/"
    
    # MIME Types
    Header always set Content-Type "application/javascript" "sw.js"
    Header always set Content-Type "application/manifest+json" "manifest.json"
    
    # Cache Control
    <FilesMatch "\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2)$">
        Header always set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    
    <FilesMatch "manifest\.json$">
        Header always set Cache-Control "public, max-age=86400"
    </FilesMatch>
    
    <FilesMatch "sw\.js$">
        Header always set Cache-Control "public, max-age=0, must-revalidate"
    </FilesMatch>
    
    # Security Headers
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# MIME Types
<IfModule mod_mime.c>
    AddType application/manifest+json .json
    AddType application/javascript .js
    AddType text/css .css
    AddType image/svg+xml .svg
</IfModule>

# Gzip Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
</IfModule>

# Error Pages
ErrorDocument 404 /index.html
ErrorDocument 500 /index.html
